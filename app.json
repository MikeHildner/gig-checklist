{
  "expo": {
    "name": "GigChecklist",
    "slug": "gig-checklist",
    "owner": "fatstreetop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "backgroundColor": "#17120B",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#17120B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gigchecklist.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#17120B"
      },
      "package": "com.gigchecklist.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "experiments": {
      "baseUrl": "/gigchecklist"
    },
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "4b528238-759b-46fa-aaf7-c64a0f6554c8"
      }
    }
  }
}
