# DiscountASP.NET FTP deployment settings.
#
# Copy this file to deploy/.env and fill in your values:
#     cp deploy/.env.example deploy/.env
#
# deploy/.env is gitignored, so your password never gets committed.
# Find these values in your DiscountASP.NET control panel (FTP / hosting account).

# FTP server hostname or IP (from the control panel).
FTP_HOST=ftp.yourdomain.com

# FTP login.
FTP_USER=your-ftp-username
FTP_PASS=your-ftp-password

# Remote target directory, relative to where FTP drops you (your site root).
# The app is served at http://hildner.org/gigchecklist, so files go in /gigchecklist.
# This MUST match the baseUrl in app.json (expo.experiments.baseUrl).
FTP_REMOTE_DIR=/gigchecklist

# FTP port. 21 is standard.
FTP_PORT=21

# Use explicit FTPS (AUTH TLS) for an encrypted transfer.
# DiscountASP.NET supports it. Set to false only if you must use plain FTP.
FTP_SECURE=true

# Set to true ONLY if the FTPS certificate fails validation (skips the cert check).
# Leave false unless you hit a TLS verification error.
FTP_TLS_INSECURE=false
