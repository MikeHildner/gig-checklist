<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for the static Expo web export (DiscountASP.NET).
  - Serves index.html as the default document.
  - Adds MIME maps. No <remove> elements: removing an extension that is not
    defined at the server level can invalidate the whole <staticContent>
    section, which silently drops the .apk mapping (HTTP 404.3). The .js/.json
    types IIS already serves by default, so we only really need .apk here.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <staticContent>
      <mimeMap fileExtension=".apk" mimeType="application/vnd.android.package-archive" />
    </staticContent>
  </system.webServer>
</configuration>
