<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for the static Expo web export (DiscountASP.NET).
  - Serves index.html as the default document.
  - Fixes MIME types. The <remove> before each <mimeMap> prevents the
    HTTP 500 "duplicate collection entry" error that occurs when IIS
    already defines the extension at the server level.
  This app uses in-memory navigation (React Navigation), so no URL-rewrite
  rule is needed. If you later switch to expo-router (real URL paths),
  add a rewrite that falls back unmatched requests to /index.html.
-->
<configuration>
  <system.webServer>
    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>
    <staticContent>
      <remove fileExtension=".js" />
      <mimeMap fileExtension=".js" mimeType="text/javascript" />
      <remove fileExtension=".mjs" />
      <mimeMap fileExtension=".mjs" mimeType="text/javascript" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".map" />
      <mimeMap fileExtension=".map" mimeType="application/json" />
      <remove fileExtension=".ttf" />
      <mimeMap fileExtension=".ttf" mimeType="font/ttf" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>
</configuration>
